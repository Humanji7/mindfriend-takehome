APP_ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000
ATLASSIAN_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=replace-me
ATLASSIAN_PROJECT_KEY=MIND
JIRA_WEBHOOK_SECRET=replace-me
JIRA_DONE_STATUS_NAMES=Done,Closed
GOOGLE_CHAT_WEBHOOK_URL=
EMAIL_FALLBACK_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=replace-me
SMTP_USE_TLS=true
GMAIL_SENDER=you@example.com
GMAIL_RECIPIENT=ops@example.com
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
NOTIFICATION_USE_LLM_SUMMARY=false
NOTIFICATION_MAX_SUMMARY_CHARS=180
SEARCH_TOP_K=3
SEARCH_MIN_SCORE=0.2
VECTOR_STORE_PATH=data/vector_store.json
INDEX_DATA_PATH=data/index_snapshot.json
